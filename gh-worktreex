#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source library scripts
source "$SCRIPT_DIR/lib/utils.sh"
source "$SCRIPT_DIR/lib/config.sh"
source "$SCRIPT_DIR/lib/hooks.sh"
source "$SCRIPT_DIR/lib/provision.sh"

# Globals with defaults
DRY_RUN=0
NO_PROVISION=0
VERBOSE=0
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || die "Not inside a git repository"
CONFIG_FILE="${REPO_ROOT}/.github/worktreex.json"
REPO_NAME="$(basename "$REPO_ROOT")"

# --- Helper functions ---

get_base_worktree() {
  git worktree list --porcelain | awk '/^worktree /{print $2; exit}'
}

extract_add_path_from_args() {
  # Best-effort parser for `git worktree add` argv to locate <path>.
  # Falls back gracefully when unknown flags are used.
  local -a args=("$@")
  local expect_value=0
  local i=0
  local arg

  while [[ "$i" -lt "${#args[@]}" ]]; do
    arg="${args[$i]}"
    if [[ "$expect_value" == "1" ]]; then
      expect_value=0
      i=$((i + 1))
      continue
    fi

    case "$arg" in
      --)
        if [[ $((i + 1)) -lt "${#args[@]}" ]]; then
          echo "${args[$((i + 1))]}"
          return 0
        fi
        return 1
        ;;
      -b|-B|--orphan|--reason)
        expect_value=1
        ;;
      -b*|-B*)
        # Support compact forms like -bfoo / -Bfoo.
        ;;
      --lock=*|--*)
        # Known long flags without positional meaning here.
        ;;
      -*)
        # Unknown short flag; keep scanning for first non-flag argument.
        ;;
      *)
        echo "$arg"
        return 0
        ;;
    esac
    i=$((i + 1))
  done

  return 1
}

list_worktree_paths_porcelain() {
  git worktree list --porcelain | awk '/^worktree /{sub(/^worktree /, "", $0); print $0}'
}

# --- Command implementations ---

cmd_add() {
  local -a add_args=()
  local known_target_path=""

  add_args=("$@")
  if [[ $# -gt 0 ]]; then
    known_target_path="$(extract_add_path_from_args "${add_args[@]}" || true)"
  fi

  local -a before_worktrees=()
  while IFS= read -r wt; do
    before_worktrees+=("$(resolve_git_worktree_path "$wt")")
  done < <(list_worktree_paths_porcelain)

  run_cmd git worktree add "${add_args[@]+"${add_args[@]}"}"

  if [[ "$DRY_RUN" == "1" ]]; then
    if [[ "$NO_PROVISION" != "1" ]]; then
      warn "Skipping provisioning in dry-run mode"
    fi
    return 0
  fi

  local wt_path=""
  if [[ -n "$known_target_path" ]]; then
    wt_path="$(resolve_path "$known_target_path")"
  fi

  # Detect the newly attached worktree path from git metadata.
  local detected_new=""
  while IFS= read -r wt; do
    local existed=0
    local resolved
    resolved="$(resolve_git_worktree_path "$wt")"
    local b
    for b in "${before_worktrees[@]+"${before_worktrees[@]}"}"; do
      if [[ "$b" == "$resolved" ]]; then
        existed=1
        break
      fi
    done
    if [[ "$existed" == "0" ]]; then
      detected_new="$resolved"
      break
    fi
  done < <(list_worktree_paths_porcelain)

  if [[ -n "$detected_new" ]]; then
    wt_path="$detected_new"
  fi
  if [[ -z "$wt_path" ]]; then
    warn "Created worktree path could not be resolved; skipping provisioning"
    return 0
  fi

  local branch
  branch="$(git -C "$wt_path" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "HEAD")"

  local should_provision=0
  if [[ "$NO_PROVISION" == "1" ]]; then
    should_provision=0
  elif [[ ! -f "$CONFIG_FILE" ]]; then
    warn "Config not found at $CONFIG_FILE; skipping provisioning. Run: gh worktreex init"
  elif ! command -v jq >/dev/null 2>&1; then
    warn "jq not found; skipping provisioning"
  elif ( config_load >/dev/null 2>&1 ); then
    should_provision=1
  else
    warn "Config validation failed; skipping provisioning"
  fi

  if [[ "$should_provision" == "1" ]]; then
    if ! provision_worktree "$wt_path" "$branch"; then
      warn "Provisioning failed for '$wt_path', but worktree creation succeeded"
    fi
  fi

  ok "Worktree ready: $wt_path (branch: $branch)"
}

cmd_pr() {
  local pr_number="${1:?Usage: gh worktreex pr <number>}"
  config_load
  require_binary gh "Install from: https://cli.github.com"

  local wt_path
  wt_path="$(dirname "$REPO_ROOT")/${REPO_NAME}-pr-${pr_number}"

  info "Checking out PR #$pr_number into $wt_path"

  # Fetch PR branch name
  local pr_branch
  pr_branch="$(gh pr view "$pr_number" --json headRefName -q '.headRefName')" \
    || die "Failed to fetch PR #$pr_number"

  # Create worktree for the PR branch
  run_cmd git fetch origin "pull/${pr_number}/head:${pr_branch}" 2>/dev/null || true
  run_cmd git worktree add "$wt_path" "$pr_branch"

  if [[ "$NO_PROVISION" != "1" ]]; then
    provision_worktree "$wt_path" "$pr_branch"
  fi

  ok "PR #$pr_number worktree ready: $wt_path (branch: $pr_branch)"
}

cmd_sync() {
  [[ $# -le 1 ]] || die "Usage: gh worktreex sync [source-path|source-branch]"

  local source_input="${1:-}"
  local current_wt current_branch
  current_wt="$(resolve_git_worktree_path "$(pwd)")"
  git -C "$current_wt" rev-parse --is-inside-work-tree >/dev/null 2>&1 \
    || die "Current directory is not a git worktree: $current_wt"
  current_branch="$(git -C "$current_wt" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "HEAD")"

  config_load

  local default_base source_wt
  default_base="$(config_get_default_base)"
  source_wt="$(find_worktree_for_branch "$default_base" || true)"
  [[ -z "$source_wt" ]] && source_wt="$(resolve_git_worktree_path "$(git rev-parse --show-toplevel)")"

  if [[ -n "$source_input" ]]; then
    if [[ -d "$source_input" ]]; then
      source_wt="$(resolve_git_worktree_path "$source_input")"
      git -C "$source_wt" rev-parse --is-inside-work-tree >/dev/null 2>&1 \
        || die "Source is not a valid git worktree: $source_wt"
    else
      source_wt="$(find_worktree_for_branch "$source_input" || true)"
      [[ -z "$source_wt" ]] && die "No worktree found for source '$source_input'"
    fi
  fi

  local in_worktree_list=0
  while IFS= read -r line; do
    echo "$line" | grep -q '(bare)' && continue
    local listed_raw listed
    listed_raw="$(echo "$line" | awk '{print $1}')"
    listed="$(resolve_git_worktree_path "$listed_raw")"
    if [[ "$listed" == "$source_wt" ]]; then
      in_worktree_list=1
      break
    fi
  done < <(git worktree list)
  [[ "$in_worktree_list" == "1" ]] || die "Source is not an attached worktree: $source_wt"

  [[ "$source_wt" == "$current_wt" ]] && die "Source and target are the same worktree: $current_wt"

  local source_branch
  source_branch="$(git -C "$source_wt" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "HEAD")"

  info "Syncing current worktree from source:"
  info "  target: $current_wt (branch: $current_branch)"
  info "  source: $source_wt (branch: $source_branch)"
  provision_worktree "$current_wt" "$current_branch" "$source_wt"
  ok "Sync complete: $current_wt"
}

cmd_status() {
  config_load
  local projects
  projects="$(config_get_projects)"

  echo ""
  while IFS= read -r line; do
    # git worktree list format: <path>  <hash>  [<branch>]  OR  <path>  <hash>  (bare)
    local wt_raw wt_path wt_branch
    wt_raw="$(echo "$line" | awk '{print $1}')"
    wt_path="$(resolve_git_worktree_path "$wt_raw")"
    wt_branch="$(echo "$line" | awk '{print $3}' | tr -d '[]')"

    # Skip bare worktrees
    echo "$line" | grep -q '(bare)' && continue

    echo -e "${BOLD}Worktree: ${wt_path}${RESET}  (${wt_branch})"

    for proj in $projects; do
      local root
      root="$(config_get_project_root "$proj")"
      local proj_path="${wt_path}/${root}"
      local nm_status="-" env_status="-" venv_status="-"

      # node_modules status
      if config_has_node "$proj"; then
        if [[ -L "${proj_path}/node_modules" ]]; then
          nm_status="$(echo -e "${GREEN}linked${RESET}")"
        elif [[ -d "${proj_path}/node_modules" ]]; then
          nm_status="$(echo -e "${GREEN}directory${RESET}")"
        else
          nm_status="$(echo -e "${RED}missing${RESET}")"
        fi
      fi

      # .venv status
      if config_has_python "$proj"; then
        if [[ -L "${proj_path}/.venv" ]]; then
          venv_status="$(echo -e "${GREEN}shared${RESET}")"
        elif [[ -d "${proj_path}/.venv" ]]; then
          venv_status="$(echo -e "${GREEN}directory${RESET}")"
        else
          venv_status="$(echo -e "${RED}missing${RESET}")"
        fi
      fi

      # .env status
      if config_has_dotenv "$proj"; then
        if [[ -L "${proj_path}/.env" ]]; then
          env_status="$(echo -e "${GREEN}linked${RESET}")"
        elif [[ -f "${proj_path}/.env" ]]; then
          env_status="$(echo -e "${GREEN}copied${RESET}")"
        else
          env_status="$(echo -e "${RED}missing${RESET}")"
        fi
      fi

      local detail=""
      config_has_node "$proj" && detail+="  node_modules: ${nm_status}"
      config_has_python "$proj" && detail+="  .venv: ${venv_status}"
      config_has_dotenv "$proj" && detail+="  .env: ${env_status}"

      echo -e "  ${BOLD}${proj}${RESET}  [${root}]${detail}"
    done

    if config_has_agent_assets; then
      local -a agent_paths=()
      while IFS= read -r p; do
        [[ -n "$p" ]] && agent_paths+=("$p")
      done < <(config_get_agent_paths)

      local agent_ok=0
      local agent_total="${#agent_paths[@]}"
      local missing_assets=""
      local ap
      for ap in "${agent_paths[@]}"; do
        if [[ -e "${wt_path}/${ap}" || -L "${wt_path}/${ap}" ]]; then
          agent_ok=$((agent_ok + 1))
        else
          missing_assets+="${ap} "
        fi
      done

      local agent_status
      if [[ "$agent_ok" -eq "$agent_total" ]]; then
        agent_status="${GREEN}${agent_ok}/${agent_total}${RESET}"
      elif [[ "$agent_ok" -gt 0 ]]; then
        agent_status="${YELLOW}${agent_ok}/${agent_total}${RESET}"
      else
        agent_status="${RED}${agent_ok}/${agent_total}${RESET}"
      fi

      if [[ -n "$missing_assets" ]]; then
        echo -e "  ${BOLD}agent-assets${RESET}  [${agent_status}] missing: ${missing_assets% }"
      else
        echo -e "  ${BOLD}agent-assets${RESET}  [${agent_status}]"
      fi
    fi
    echo ""
  done < <(git worktree list)
}

cmd_list() {
  run_cmd git worktree list "$@"
}

cmd_remove() {
  # Usage: gh worktreex remove [-f] <path|branch>
  local force=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--force) force=1; shift ;;
      *) break ;;
    esac
  done

  local target="${1:?Usage: gh worktreex remove [-f] <path|branch>}"

  # If target looks like a branch name, find its worktree path
  local wt_path="$target"
  if [[ ! -d "$target" ]]; then
    wt_path="$(git worktree list --porcelain | awk -v b="$target" '
      /^worktree /{wt=$2}
      /^branch /{if ($2 == "refs/heads/"b) print wt}
    ')"
    [[ -z "$wt_path" ]] && die "No worktree found for '$target'"
  fi

  wt_path="$(resolve_path "$wt_path")"

  # Detect the branch
  local branch
  branch="$(git -C "$wt_path" rev-parse --abbrev-ref HEAD 2>/dev/null)" || true

  info "Removing worktree at $wt_path"
  local force_flag="--force"
  [[ "$force" == "0" ]] && force_flag=""
  run_cmd git worktree remove ${force_flag:+"$force_flag"} "$wt_path"

  if [[ -n "$branch" && "$branch" != "HEAD" ]]; then
    echo -n "Delete branch '$branch'? [y/N] "
    read -r answer
    if [[ "$answer" =~ ^[Yy] ]]; then
      run_cmd git branch -D "$branch"
      ok "Branch '$branch' deleted"
    fi
  fi

  ok "Worktree removed: $wt_path"
}

cmd_prune() {
  info "Pruning stale worktrees..."
  run_cmd git worktree prune

  local default_base
  default_base="$(config_get_default_base 2>/dev/null || echo "main")"

  # Find worktrees on merged branches
  while IFS= read -r line; do
    local wt_raw wt_path wt_branch
    wt_raw="$(echo "$line" | awk '{print $1}')"
    wt_path="$(resolve_git_worktree_path "$wt_raw")"
    wt_branch="$(echo "$line" | awk '{print $3}' | tr -d '[]')"

    [[ "$wt_branch" == "$default_base" ]] && continue
    [[ -z "$wt_branch" ]] && continue

    # Check if branch is merged into default_base
    if git branch --merged "$default_base" 2>/dev/null | grep -q "^\s*${wt_branch}$"; then
      echo -n "Branch '$wt_branch' is merged. Remove worktree at $wt_path? [y/N] "
      read -r answer
      if [[ "$answer" =~ ^[Yy] ]]; then
        run_cmd git worktree remove --force "$wt_path"
        run_cmd git branch -d "$wt_branch"
        ok "Removed: $wt_path ($wt_branch)"
      fi
    fi
  done < <(git worktree list)

  ok "Clean complete"
}

# --- Argument parsing ---

usage() {
  echo "Usage: gh worktreex <command> [flags]"
  echo ""
  echo "Unrecognized commands are forwarded to: git worktree <command> ..."
  echo ""
  echo "Commands:"
  echo "  init                              Scaffold .github/worktreex.json"
  echo "  add  [git-worktree-add-args]      Native git worktree add + optional provisioning"
  echo "  pr   <number>                     Checkout PR in a worktree + provision"
  echo "  sync [source-path|source-branch]  Re-provision current worktree from source"
  echo "  list [git-list-args]              Native git worktree list passthrough"
  echo "  status                            Show provisioning state across worktrees"
  echo "  rm [-f] <path|branch>             Special remove flow (prompt branch delete)"
  echo "  clean                             Special cleanup flow for merged branches"
  echo ""
  echo "Global flags:"
  echo "  --no-provision       Skip provisioning"
  echo "  --dry-run            Print what would be done"
  echo "  --config <file>      Path to config file"
  echo "  -v, --verbose        Verbose output"
}

# Parse leading global flags only.
# Everything after the command token belongs to that command verbatim.
while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-provision) NO_PROVISION=1; shift ;;
    --dry-run)      DRY_RUN=1; shift ;;
    --config)       CONFIG_FILE="$2"; shift 2 ;;
    -v|--verbose)   VERBOSE=1; shift ;;
    -h|--help)      usage; exit 0 ;;
    --)             shift; break ;;
    -*)             break ;;
    *)              break ;;
  esac
done

COMMAND="${1:-}"
[[ $# -gt 0 ]] && shift

case "$COMMAND" in
  init)
    if [[ -f "$SCRIPT_DIR/lib/init.sh" ]]; then
      source "$SCRIPT_DIR/lib/init.sh"
      cmd_init "$@"
    else
      die "init.sh not found"
    fi
    ;;
  add)           cmd_add "$@" ;;
  pr)            cmd_pr "$@" ;;
  sync)          cmd_sync "$@" ;;
  list)          cmd_list "$@" ;;
  status)        cmd_status "$@" ;;
  rm)            cmd_remove "$@" ;;
  clean)         cmd_prune "$@" ;;
  "")            usage; exit 1 ;;
  *)
    run_cmd git worktree "$COMMAND" "$@"
    ;;
esac
