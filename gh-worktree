#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"
SCRIPT_NAME="gh worktree"

# ─── Colors ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

# ─── Helpers ──────────────────────────────────────────────────────────────────
die()  { echo -e "${RED}Error:${RESET} $*" >&2; exit 1; }
info() { echo -e "${CYAN}→${RESET} $*"; }
ok()   { echo -e "${GREEN}✔${RESET} $*"; }
warn() { echo -e "${YELLOW}!${RESET} $*"; }

require_git_repo() {
  git rev-parse --git-dir &>/dev/null || die "Not inside a git repository."
}

# ─── Usage ────────────────────────────────────────────────────────────────────
usage() {
  cat <<EOF
${BOLD}${SCRIPT_NAME}${RESET} — Manage git worktrees with GitHub context  (v${VERSION})

${BOLD}USAGE${RESET}
  gh worktree <command> [flags]

${BOLD}COMMANDS${RESET}
  list                 List all worktrees for this repo
  new  <branch>        Create a new worktree for <branch> (creates branch if absent)
  pr   <number>        Create a worktree from a GitHub Pull Request
  rm   <path|branch>   Remove a worktree (and optionally delete its branch)
  clean                Remove all worktrees whose branches are merged / deleted
  cd   <path|branch>   Print the path of a worktree (use with: cd \$(gh worktree cd …))

${BOLD}FLAGS${RESET}
  -h, --help           Show this help
  -v, --version        Show version

${BOLD}EXAMPLES${RESET}
  gh worktree list
  gh worktree new feature/my-thing
  gh worktree pr 42
  gh worktree rm feature/my-thing
  gh worktree clean
  cd \$(gh worktree cd 42)
EOF
}

# ─── Command: list ────────────────────────────────────────────────────────────
cmd_list() {
  require_git_repo
  echo -e "${BOLD}Worktrees:${RESET}"
  git worktree list --porcelain | awk '
    /^worktree / { path=$2 }
    /^HEAD /     { head=substr($2,1,7) }
    /^branch /   { branch=$2; sub("refs/heads/","",branch) }
    /^$/         {
      if (path != "") {
        printf "  %-45s %s  %s\n", path, head, branch
        path=""; head=""; branch=""
      }
    }
    END { if (path != "") printf "  %-45s %s  %s\n", path, head, branch }
  '
}

# ─── Command: new ─────────────────────────────────────────────────────────────
cmd_new() {
  require_git_repo
  local branch="${1:-}"
  [[ -z "$branch" ]] && die "Usage: gh worktree new <branch>"

  local root
  root="$(git rev-parse --show-toplevel)"
  local safe_branch
  safe_branch="${branch//\//-}"          # replace / with - for directory name
  local wt_dir="${root}/../$(basename "$root")-${safe_branch}"
  wt_dir="$(realpath -m "$wt_dir")"

  if git show-ref --verify --quiet "refs/heads/${branch}"; then
    info "Branch '${branch}' already exists — checking it out in a new worktree."
    git worktree add "$wt_dir" "$branch"
  else
    info "Creating branch '${branch}' and worktree at ${wt_dir}"
    git worktree add -b "$branch" "$wt_dir"
  fi

  ok "Worktree ready at: ${BOLD}${wt_dir}${RESET}"
  echo "$wt_dir"
}

# ─── Command: pr ──────────────────────────────────────────────────────────────
cmd_pr() {
  require_git_repo
  local pr_number="${1:-}"
  [[ -z "$pr_number" ]] && die "Usage: gh worktree pr <pr-number>"

  command -v gh &>/dev/null || die "'gh' CLI not found. Install from https://cli.github.com"

  info "Fetching PR #${pr_number} details…"
  local pr_json
  pr_json="$(gh pr view "$pr_number" --json headRefName,title,number,headRepositoryOwner,headRepository)"

  local branch title
  branch="$(echo "$pr_json" | gh api /repos/:owner/:repo/pulls/"$pr_number" --jq '.head.ref' 2>/dev/null)" || \
  branch="$(echo "$pr_json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['headRefName'])" 2>/dev/null)" || \
  branch="$(gh pr view "$pr_number" --json headRefName --jq '.headRefName')"
  title="$(gh pr view "$pr_number" --json title --jq '.title')"

  info "PR #${pr_number}: ${title}"
  info "Branch: ${branch}"

  local root
  root="$(git rev-parse --show-toplevel)"
  local safe_branch="${branch//\//-}"
  local wt_dir="${root}/../$(basename "$root")-pr-${pr_number}"
  wt_dir="$(realpath -m "$wt_dir")"

  info "Fetching branch from remote…"
  gh pr checkout "$pr_number" --detach 2>/dev/null || true

  if [[ -d "$wt_dir" ]]; then
    warn "Worktree already exists at ${wt_dir}"
  else
    git fetch origin "${branch}:${branch}" 2>/dev/null || \
      git fetch origin "pull/${pr_number}/head:pr/${pr_number}"

    local checkout_branch="$branch"
    if ! git show-ref --verify --quiet "refs/heads/${branch}"; then
      checkout_branch="pr/${pr_number}"
    fi
    git worktree add "$wt_dir" "$checkout_branch"
    ok "Worktree ready at: ${BOLD}${wt_dir}${RESET}"
  fi
  echo "$wt_dir"
}

# ─── Command: rm ──────────────────────────────────────────────────────────────
cmd_rm() {
  require_git_repo
  local target="${1:-}"
  [[ -z "$target" ]] && die "Usage: gh worktree rm <path|branch>"

  # Resolve: is it a path or a branch name?
  local wt_path=""
  if [[ -d "$target" ]]; then
    wt_path="$(realpath "$target")"
  else
    # Try to find by branch name
    wt_path="$(git worktree list --porcelain \
      | awk -v branch="refs/heads/${target}" '
          /^worktree / { p=$2 }
          $0 == "branch " branch { print p; exit }
        ')"
  fi

  [[ -z "$wt_path" ]] && die "No worktree found for '${target}'"

  local main_wt
  main_wt="$(git worktree list --porcelain | awk 'NR==2{print $2}')"
  [[ "$wt_path" == "$(git rev-parse --show-toplevel)" ]] && \
    die "Cannot remove the main worktree."

  info "Removing worktree: ${wt_path}"
  git worktree remove --force "$wt_path"
  ok "Removed."

  # Offer to delete the branch
  local branch
  branch="$(git worktree list --porcelain 2>/dev/null \
    | awk -v p="$wt_path" '/^worktree /{cur=$2} cur==p && /^branch /{print $2}' \
    | sed 's|refs/heads/||')" || true
  if [[ -n "$branch" ]]; then
    read -r -p "$(echo -e "Delete branch '${branch}' too? [y/N] ")" yn
    if [[ "$yn" =~ ^[Yy]$ ]]; then
      git branch -d "$branch" 2>/dev/null || git branch -D "$branch"
      ok "Branch '${branch}' deleted."
    fi
  fi
}

# ─── Command: clean ───────────────────────────────────────────────────────────
cmd_clean() {
  require_git_repo
  info "Pruning stale worktree metadata…"
  git worktree prune

  local merged_branches
  merged_branches="$(git branch --merged HEAD --format='%(refname:short)' 2>/dev/null | grep -v '^main$\|^master$\|^develop$' || true)"

  if [[ -z "$merged_branches" ]]; then
    ok "Nothing to clean."
    return
  fi

  echo -e "${YELLOW}Merged branches:${RESET}"
  echo "$merged_branches" | sed 's/^/  /'

  # Find worktrees on merged branches
  while IFS= read -r branch; do
    local wt_path
    wt_path="$(git worktree list --porcelain \
      | awk -v b="refs/heads/${branch}" '
          /^worktree / { p=$2 }
          $0 == "branch " b { print p; exit }
        ')"
    if [[ -n "$wt_path" && "$wt_path" != "$(git rev-parse --show-toplevel)" ]]; then
      read -r -p "$(echo -e "Remove worktree for merged branch '${branch}' at ${wt_path}? [y/N] ")" yn
      if [[ "$yn" =~ ^[Yy]$ ]]; then
        git worktree remove --force "$wt_path"
        git branch -d "$branch" 2>/dev/null || true
        ok "Removed ${wt_path} and deleted branch '${branch}'."
      fi
    fi
  done <<< "$merged_branches"

  git worktree prune
  ok "Clean complete."
}

# ─── Command: cd ──────────────────────────────────────────────────────────────
cmd_cd() {
  require_git_repo
  local target="${1:-}"
  [[ -z "$target" ]] && die "Usage: gh worktree cd <path|branch|pr-number>"

  # Try as PR number first
  if [[ "$target" =~ ^[0-9]+$ ]]; then
    local root
    root="$(git rev-parse --show-toplevel)"
    local wt_dir="${root}/../$(basename "$root")-pr-${target}"
    if [[ -d "$wt_dir" ]]; then
      echo "$(realpath "$wt_dir")"
      return
    fi
  fi

  # Try as directory
  if [[ -d "$target" ]]; then
    echo "$(realpath "$target")"
    return
  fi

  # Try as branch name
  local wt_path
  wt_path="$(git worktree list --porcelain \
    | awk -v b="refs/heads/${target}" '
        /^worktree / { p=$2 }
        $0 == "branch " b { print p; exit }
      ')"
  [[ -n "$wt_path" ]] && echo "$wt_path" && return

  die "No worktree found for '${target}'"
}

# ─── Entry point ──────────────────────────────────────────────────────────────
main() {
  local cmd="${1:-}"

  case "$cmd" in
    list)              shift; cmd_list "$@" ;;
    new)               shift; cmd_new "$@" ;;
    pr)                shift; cmd_pr "$@" ;;
    rm|remove)         shift; cmd_rm "$@" ;;
    clean)             shift; cmd_clean "$@" ;;
    cd)                shift; cmd_cd "$@" ;;
    -v|--version)      echo "gh-worktree v${VERSION}" ;;
    -h|--help|help|"") usage ;;
    *)                 die "Unknown command: '${cmd}'. Run 'gh worktree --help'." ;;
  esac
}

main "$@"
